[Unit]
Description=claude-research-bot ARO — one autonomous research cycle
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/gabrielmarquez147/claude-research-work
ExecStart=/home/gabrielmarquez147/claude-research-work/scripts/supervisor.sh
# claude CLI lives in ~/.local/bin
Environment=HOME=/home/gabrielmarquez147
Environment=PATH=/home/gabrielmarquez147/.local/bin:/usr/local/bin:/usr/bin:/bin
# A cycle should not run forever; supervisor also enforces its own timeout.
TimeoutStartSec=3600
Nice=10
# Keep full-auto runs scoped to the research bot and local Claude state.
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/gabrielmarquez147/claude-research-work /home/gabrielmarquez147/.claude /home/gabrielmarquez147/.config /home/gabrielmarquez147/.local /tmp
RestrictSUIDSGID=true
LockPersonality=true

[Install]
WantedBy=default.target
